// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum SeatClass {
  ECONOMY
  BUSINESS
  FIRST
}

enum SeatStatus {
  AVAILABLE
  BOOKED
  RESERVED
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum PassengerType {
  ADULT
  CHILD
  INFANT
}

enum PaymentMethod {
  MIDTRANS
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum FlightStatus {
  SCHEDULED
  DELAYED
  CANCELLED
}

enum documentType {
  KTP
  PASSPORT
}

model User {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(50)
  email         String    @unique @db.VarChar(100)
  password      String    @db.VarChar(255) // bcrypt safe
  phone         String?   @db.VarChar(20)
  avatarUrl     String?   @db.Text
  role          Role      @default(USER)
  isBlocked     Boolean   @default(false)
  resetToken    String?   @db.VarChar(255)
  resetExpire   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
}

model Airport {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(100)
  city             String    @db.VarChar(100)
  country          String    @db.VarChar(100)
  timezone         String?   @db.VarChar(50)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  departureFlights Flight[]  @relation("DepartureAirport")
  arrivalFlights   Flight[]  @relation("ArrivalAirport")
}

model Airline {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(10)
  name      String   @db.VarChar(100)
  country   String   @default("Unknown") @db.VarChar(100)
  logo      String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flights   Flight[]
}

model Flight {
  id              Int          @id @default(autoincrement())
  flightNumber    String       @unique @db.VarChar(20)
  airlineId       Int
  originId        Int
  destinationId   Int
  departureTime   DateTime
  arrivalTime     DateTime
  duration        Int
  basePrice       Int
  tax             Int          @default(0)
  adminFee        Int          @default(0)
  aircraft        String?      @db.VarChar(100)
  facilities      String?      @db.VarChar(255)
  rules           String?      @db.Text
  status          FlightStatus @default(SCHEDULED)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  airline         Airline      @relation(fields: [airlineId], references: [id])
  origin          Airport      @relation("DepartureAirport", fields: [originId], references: [id])
  destination     Airport      @relation("ArrivalAirport", fields: [destinationId], references: [id])
  bookings        Booking[]
  flightSeats     FlightSeat[]
}

model Seat {
  id          Int        @id @default(autoincrement())
  seatNumber  String     @db.VarChar(5)
  seatClass   SeatClass  @default(ECONOMY)
  isExitRow   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  flightSeats FlightSeat[]

  @@unique([seatNumber, seatClass])
}

model FlightSeat {
  id              Int        @id @default(autoincrement())
  flightId        Int
  seatId          Int
  status          SeatStatus @default(AVAILABLE)
  additionalPrice Int        @default(0)
  bookingId       Int?       // FIXED (optional)

  flight          Flight     @relation(fields: [flightId], references: [id], onDelete: Cascade)
  seat            Seat       @relation(fields: [seatId], references: [id])
  booking         Booking?   @relation(fields: [bookingId], references: [id])

  @@unique([flightId, seatId])
}

model Booking {
  id             Int           @id @default(autoincrement())
  bookingCode    String        @unique @db.VarChar(20)
  userId         Int
  flightId       Int
  status         BookingStatus @default(PENDING)
  totalPrice     Int
  selectedSeats  String?       @db.VarChar(255) // Nomor kursi terpilih, dipisah koma (misal "7A,7B")
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  flight        Flight        @relation(fields: [flightId], references: [id])
  passengers    Passenger[]
  payment       Payment?
  ticket        Ticket?
  flightSeats   FlightSeat[]
}

model Passenger {
  id                Int           @id @default(autoincrement())
  bookingId         Int
  type              PassengerType
  title             String        @db.VarChar(10)
  firstName         String        @db.VarChar(50)
  lastName          String        @db.VarChar(50)
  documentType      documentType  @default(KTP) // Jenis dokumen: KTP atau PASSPORT
  documentNumber    String        @db.VarChar(16)   // Nomor NIK (16 digit) atau nomor paspor
  documentImageUrl  String?       @db.VarChar(500)  // URL gambar scan KTP/paspor di MinIO
  nationality       String        @db.VarChar(50)
  dateOfBirth       DateTime?
  createdAt         DateTime      @default(now())

  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id              Int           @id @default(autoincrement())
  bookingId       Int           @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Int
  paymentProof    String?       @db.VarChar(255)
  transactionId   String?       @db.VarChar(100)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Ticket {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique
  ticketNumber  String   @unique @db.VarChar(30)
  qrCode        String   @db.VarChar(255)
  pdfUrl        String?  @db.VarChar(255)
  issuedAt      DateTime @default(now())

  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}